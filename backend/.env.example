QWEN_MODEL=qwen2.5-7b-instruct
GEMINI_MODEL=gemini-pro

# Redis (Celery broker)
REDIS_URL=redis://localhost:6379/0

# App
ENVIRONMENT=development
SECRET_KEY=change-me

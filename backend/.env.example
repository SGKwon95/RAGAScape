DATABASE_URL=postgresql+asyncpg://postgres.caljiwqckktvxcpvzzmi:[YOUR-PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?prepared_statement_cache_size=0

# LLM API keys
